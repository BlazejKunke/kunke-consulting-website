---
import BaseLayout from '../components/BaseLayout.astro';
import AiPackages from '../components/AiPackages.astro';
import ContactForm from '../components/ContactForm.astro';
import Testimonials from '../components/testimonials.astro';

---

<BaseLayout 
  title="Szkolenia AI Poznań i Wielkopolska dla firm | ^Kunke Consulting"
  description="Praktyczne, zamknięte szkolenia AI dla firm z Poznania, Wielkopolski i okolic Inowrocławia. Dwa dni warsztatów, materiały i plan wdrożenia."
  ogImage="/images/Kunke_Favicon.png"
>

<style>
  .hero-poznan {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 80px 20px;
    text-align: center;
  }
  .hero-poznan h1 {
    font-size: 3rem;
    margin-bottom: 20px;
    font-weight: 700;
    color: white;
  }
  .hero-poznan p {
    font-size: 1.3rem;
    margin-bottom: 30px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  .local-benefits {
    padding: 60px 20px;
    background: #f8f8fa;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .benefit-card {
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 12px rgba(0,0,0,.06);
    text-align: center;
  }
  .benefit-icon {
    font-size: 3rem;
    margin-bottom: 15px;
    display: block;
  }
  .poznań-stats {
    padding: 60px 20px;
    background: white;
    text-align: center;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
    max-width: 800px;
    margin: 40px auto 0;
  }
  .stat-card {
    background: #f8f8fa;
    padding: 30px 20px;
    border-radius: 12px;
  }
  .stat-number {
    font-size: 2.5rem;
    font-weight: bold;
    color: #667eea;
    margin-bottom: 10px;
    display: block;
  }
  .local-companies {
    padding: 60px 20px;
    background: #f8f8fa;
  }
  .companies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    max-width: 1000px;
    margin: 0 auto;
  }
  .company-item {
    background: white;
    padding: 20px;
    border-radius: 8px;
    text-align: center;
    border-top: 3px solid #667eea;
  }
  .cta-btn {
    display: inline-block;
    background: #667eea;
    color: white;
    padding: 15px 30px;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    margin-top: 20px;
    transition: all 0.3s ease;
  }
  .cta-btn:hover {
    background: #5a67d8;
    transform: translateY(-2px);
  }
  @media (max-width: 768px) {
    .hero-poznan h1 {
      font-size: 2rem;
    }
    .hero-poznan p {
      font-size: 1.1rem;
    }
  }
</style>

<section class="hero-poznan">
  <h1>Szkolenia AI dla firm w Poznaniu i Wielkopolsce</h1>
  <p>
    Zamknięte, praktyczne warsztaty dla zespołów z Poznania, Wielkopolski, Inowrocławia i okolic.
    Program powstaje na podstawie realnych procesów firmy, poziomu zespołu i zasad bezpiecznej pracy z danymi.
  </p>
  <a href="/ai-workshop/" class="cta-btn">Zobacz program warsztatów AI</a>
</section>

<section class="local-benefits">
  <h2 style="text-align: center; margin-bottom: 50px;">Dlaczego szkolenia AI dla firm w Wielkopolsce?</h2>
  <div class="benefits-grid">
    <div class="benefit-card">
      <span class="benefit-icon">🏢</span>
      <h3>Szkolenia u Ciebie</h3>
      <p>Warsztat może odbyć się w siedzibie firmy, dzięki czemu cały zespół pracuje na przykładach z własnego środowiska.</p>
    </div>
    <div class="benefit-card">
      <span class="benefit-icon">🚗</span>
      <h3>Cała Wielkopolska i okolice</h3>
      <p>Dojeżdżamy m.in. do Poznania, Gniezna, Konina, Kalisza, Leszna i Piły oraz do firm z rejonu Inowrocławia.</p>
    </div>
    <div class="benefit-card">
      <span class="benefit-icon">🤝</span>
      <h3>Program dopasowany do MŚP</h3>
      <p>Zakres dobieramy do procesów, branży, narzędzi i ryzyk firmy — bez technicznego żargonu i przypadkowych demonstracji.</p>
    </div>
    <div class="benefit-card">
      <span class="benefit-icon">📞</span>
      <h3>Od warsztatu do pilotażu</h3>
      <p>Po szkoleniu zespół ma materiały, scenariusze użycia i plan pierwszych działań, które można dalej rozwijać w projekcie.</p>
    </div>
  </div>
</section>

<section class="poznań-stats">
  <h2>Konkretny format szkolenia dla firmy</h2>
  <div class="stats-grid">
    <div class="stat-card">
      <span class="stat-number">2 dni</span>
      <h4>Dwa dopasowane dni szkoleniowe</h4>
    </div>
    <div class="stat-card">
      <span class="stat-number">10 h</span>
      <h4>Łącznie około dziesięciu godzin pracy</h4>
    </div>
    <div class="stat-card">
      <span class="stat-number">6000 zł</span>
      <h4>Cena od 6000 zł + VAT</h4>
    </div>
    <div class="stat-card">
      <span class="stat-number">PL / EN</span>
      <h4>Szkolenia po polsku lub po angielsku</h4>
    </div>
  </div>
</section>

<section class="local-companies">
  <h2 style="text-align: center; margin-bottom: 50px;">Przykładowe obszary dla firm z regionu</h2>
  <div class="companies-grid">
    <div class="company-item">
      <h4>🏭 Produkcja</h4>
      <p>Instrukcje, raporty, oferty, analiza dokumentacji i usprawnianie powtarzalnej pracy biurowej.</p>
    </div>
    <div class="company-item">
      <h4>⚖️ Usługi profesjonalne</h4>
      <p>Praca z dokumentami, research, przygotowanie pierwszych wersji materiałów i bezpieczne korzystanie z danych.</p>
    </div>
    <div class="company-item">
      <h4>📊 Finanse i administracja</h4>
      <p>Podsumowania, kontrola jakości, analiza tabel, obieg informacji i wsparcie raportowania.</p>
    </div>
    <div class="company-item">
      <h4>🛒 Sprzedaż i marketing</h4>
      <p>Przygotowanie ofert, analiza rozmów, research klientów oraz tworzenie i weryfikacja treści.</p>
    </div>
    <div class="company-item">
      <h4>👥 HR i rozwój ludzi</h4>
      <p>Materiały szkoleniowe, komunikacja wewnętrzna, onboarding i projektowanie zasad odpowiedzialnego użycia AI.</p>
    </div>
    <div class="company-item">
      <h4>🧭 Zarządy i managerowie</h4>
      <p>Priorytety zastosowań, ryzyka, governance i wybór pierwszego pilotażu z mierzalnym efektem.</p>
    </div>
  </div>
</section>

<section style="padding: 60px 20px; background: white; text-align: center;">
  <h2>Ten sam standard szkolenia w całym regionie</h2>
  <div style="max-width: 800px; margin: 0 auto; text-align: left;">
    <p>
      Prowadzimy ten sam, dopasowany do firmy warsztat niezależnie od miasta. Lokalizacja wpływa na organizację
      i dojazd, ale nie zmienia standardu pracy. Jeśli zespół jest rozproszony, szkolenie może odbyć się online.
    </p>
    <p>
      Jeżeli nie wiesz, czy potrzebujesz szkolenia, zacznij od
      <a href="/konsultacja-ai/">90-minutowej konsultacji AI</a>. Jeśli firma ma już wybrany proces i chce przejść
      do pilotażu, zobacz <a href="/projekty-ai/">projekty i wdrożenia AI</a>.
    </p>
  </div>
</section>

<section style="padding: 60px 20px; background: white; text-align: center;">
  <h2>Co wyróżnia nasze szkolenia AI w Poznaniu?</h2>
  <div style="max-width: 800px; margin: 0 auto; text-align: left;">
    <ul style="list-style: none; padding: 0;">
      <li style="padding: 15px; margin-bottom: 10px; background: #f8f8fa; border-radius: 8px; border-left: 4px solid #667eea;"><strong>🎯 Praktyczne podejście:</strong> Ćwiczenia odnoszą się do realnych procesów, z ochroną informacji poufnych</li>
      <li style="padding: 15px; margin-bottom: 10px; background: #f8f8fa; border-radius: 8px; border-left: 4px solid #667eea;"><strong>🇵🇱 Język polski:</strong> Wszystkie materiały i szkolenia prowadzone w języku polskim</li>
      <li style="padding: 15px; margin-bottom: 10px; background: #f8f8fa; border-radius: 8px; border-left: 4px solid #667eea;"><strong>📚 Kompleksowe materiały:</strong> Otrzymujesz pakiet materiałów i przykładów do wykorzystania</li>
      <li style="padding: 15px; margin-bottom: 10px; background: #f8f8fa; border-radius: 8px; border-left: 4px solid #667eea;"><strong>⏰ Elastyczne terminy:</strong> Dostosowujemy się do Twojego kalendarza</li>
      <li style="padding: 15px; margin-bottom: 10px; background: #f8f8fa; border-radius: 8px; border-left: 4px solid #667eea;"><strong>💼 Dalsze kroki:</strong> Scenariusze użycia, playbook i plan pierwszego pilotażu po warsztacie</li>
    </ul>
  </div>
</section>

<!-- AI Packages Section -->
<section id="ai-packages">
  <AiPackages />
</section>

<section style="padding: 60px 20px; background: #667eea; color: white; text-align: center;">
  <h2 style="color: white;">Porozmawiajmy o warsztacie AI dla Twojego zespołu</h2>
  <p style="font-size: 1.2rem; margin-bottom: 30px; max-width: 700px; margin-left: auto; margin-right: auto;">
    Napisz, ile osób ma wziąć udział, czym zajmuje się firma i które procesy najbardziej obciążają zespół.
  </p>
  <a href="#contact" class="cta-btn" style="background: white; color: #667eea;">Zapytaj o szkolenie w regionie</a>
</section>

<!-- Testimonials Section -->
<section id="testimonials">
  <Testimonials />
</section>

<section id="contact" style="padding: 60px 20px; background: #f8f8fa;">
  <h2 style="text-align: center; margin-bottom: 30px;">Skontaktuj się — szkolenia AI w regionie</h2>
  <p style="text-align: center; margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">
    Chcesz dowiedzieć się więcej o szkoleniu w Poznaniu, Wielkopolsce lub okolicach Inowrocławia?
    Skontaktuj się z nami i omówmy potrzeby szkoleniowe Twojej firmy.
  </p>
  <div style="text-align: center; margin-bottom: 30px;">
    <p><strong>📍 Poznań, Wielkopolska, Inowrocław i okolice</strong></p>
    <p><strong>📞 Telefon:</strong> <a href="tel:+48722156925">+48 722 156 925</a></p>
    <p><strong>✉️ Email:</strong> <a href="mailto:info@kunkeconsulting.pl">info@kunkeconsulting.pl</a></p>
  </div>
  <ContactForm />
</section>

</BaseLayout>
