---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => post.data.language === "en")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const canonicalUrl = "https://kunkeconsulting.pl/en/blog/";
---

<!DOCTYPE html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/Kunke_Favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/global.css" />
    <title>Practical AI Insights | ^Kunke Consulting Blog</title>
    <meta name="description" content="Practical articles on AI training, implementation, strategy, and responsible adoption for international teams." />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <style>
      body { background: #f8f5ed; color: #17362e; }
      .blog-shell { width: min(1080px, calc(100% - 40px)); margin: 0 auto; }
      .blog-nav { display: flex; justify-content: space-between; align-items: center; padding: 28px 0; }
      .blog-nav a { color: #17362e; font-weight: 700; text-decoration: none; }
      .blog-hero { padding: 72px 0 52px; max-width: 760px; }
      .eyebrow { color: #a4522d; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
      h1 { font-size: clamp(2.5rem, 6vw, 4.8rem); line-height: 1.02; margin: 14px 0 24px; }
      .intro { font-size: 1.25rem; line-height: 1.7; color: #3f574f; }
      .post-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 24px; padding-bottom: 80px; }
      .post-card { background: #fff; border: 1px solid rgba(23,54,46,.12); border-radius: 18px; overflow: hidden; box-shadow: 0 10px 30px rgba(23,54,46,.06); }
      .post-card img { display: block; width: 100%; height: 230px; object-fit: cover; background: #e8e1d4; }
      .post-content { padding: 28px; }
      .post-content time { color: #7b3f24; font-size: .9rem; font-weight: 700; }
      .post-content h2 { font-size: 1.45rem; margin: 12px 0; }
      .post-content h2 a { color: #17362e; text-decoration: none; }
      .post-content p { color: #52665f; line-height: 1.6; }
      .read-more { display: inline-block; color: #a4522d; font-weight: 700; text-decoration: none; margin-top: 10px; }
      .blog-footer { border-top: 1px solid rgba(23,54,46,.15); padding: 30px 0 50px; }
      .blog-footer a { color: #17362e; font-weight: 700; text-decoration: none; }
      @media (max-width: 720px) { .post-grid { grid-template-columns: 1fr; } .blog-hero { padding-top: 40px; } }
    </style>
  </head>
  <body>
    <div class="blog-shell">
      <nav class="blog-nav" aria-label="Blog navigation">
        <a href="/en/">^Kunke Consulting</a>
        <a href="/en/#contact">Contact</a>
      </nav>

      <header class="blog-hero">
        <p class="eyebrow">Practical AI insights</p>
        <h1>Clear thinking about AI at work</h1>
        <p class="intro">Field notes on AI strategy, implementation, and responsible adoption for leaders and teams working across borders.</p>
      </header>

      <main class="post-grid">
        {posts.map((post) => (
          <article class="post-card">
            <a href={`/blog/${post.slug}/`} aria-label={`Read ${post.data.title}`}>
              <img src={post.data.heroImage || "/images/Workshop2025.JPG"} alt="" loading="lazy" decoding="async" width="520" height="230" />
            </a>
            <div class="post-content">
              <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
              <h2><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <a class="read-more" href={`/blog/${post.slug}/`}>Read article →</a>
            </div>
          </article>
        ))}
      </main>

      <footer class="blog-footer">
        <a href="/en/">← Back to the English homepage</a>
      </footer>
    </div>
  </body>
</html>
