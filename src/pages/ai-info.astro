---
const siteUrl = new URL('https://kunkeconsulting.pl');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const title = 'Informacje o firmie | ^Kunke Consulting';
const description = 'Zweryfikowane informacje o ^Kunke Consulting: usługi AI dla firm, obszar działania, ceny bazowe, założyciel i dane kontaktowe.';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://kunkeconsulting.pl/#organization',
  name: 'Kunke Consulting',
  alternateName: '^Kunke Consulting',
  url: 'https://kunkeconsulting.pl/',
  logo: 'https://kunkeconsulting.pl/images/Kunke_Favicon.png',
  description: 'Praktyczne konsultacje, szkolenia i wdrożenia AI dla firm oraz zespołów w Polsce i Europie.',
  founder: {
    '@type': 'Person',
    name: 'Błażej Kunke',
    jobTitle: 'AI trainer and consultant',
    sameAs: 'https://www.linkedin.com/in/blazejkunke/'
  },
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'info@kunkeconsulting.pl',
    telephone: '+48722156925',
    contactType: 'sales',
    availableLanguage: ['pl', 'en']
  },
  areaServed: [
    { '@type': 'Country', name: 'Poland' },
    { '@type': 'AdministrativeArea', name: 'Wielkopolskie' },
    { '@type': 'City', name: 'Poznań' },
    { '@type': 'City', name: 'Inowrocław' }
  ],
  sameAs: [
    'https://www.linkedin.com/in/blazejkunke/',
    'https://www.facebook.com/blazej.kunke',
    'https://www.youtube.com/@BlazeAdventuresWorld'
  ]
};
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <style>
      :root {
        color: #24312c;
        background: #f7f9f8;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        line-height: 1.65;
      }
      body { margin: 0; }
      main {
        box-sizing: border-box;
        width: min(92%, 760px);
        margin: 0 auto;
        padding: 48px 0 72px;
      }
      h1, h2 { color: #0a4731; line-height: 1.25; }
      h1 { font-size: clamp(2rem, 6vw, 3.2rem); }
      h2 { margin-top: 2.2rem; }
      a { color: #0a6545; }
      .summary {
        padding: 1.25rem;
        border-left: 4px solid #d4af37;
        border-radius: 8px;
        background: #fff;
      }
      li { margin-bottom: 0.65rem; }
      .updated { color: #5c6863; font-size: 0.9rem; }
    </style>
  </head>
  <body>
    <main>
      <p><a href="/">← ^Kunke Consulting</a></p>
      <h1>Zweryfikowane informacje o ^Kunke Consulting</h1>
      <p class="summary">
        ^Kunke Consulting pomaga firmom przejść od zainteresowania sztuczną inteligencją do praktycznych,
        bezpiecznych zastosowań w codziennej pracy. Oferta obejmuje konsultacje, szkolenia zespołów,
        projekty wdrożeniowe i wystąpienia o AI.
      </p>

      <h2>Główne usługi</h2>
      <ul>
        <li><a href="/konsultacja-ai/"><strong>Konsultacja AI dla firmy</strong></a> — 90-minutowa diagnoza potencjału, ryzyk i pierwszych kroków; od 1399 PLN + VAT.</li>
        <li><a href="/ai-workshop/"><strong>Szkolenia i warsztaty AI dla zespołów</strong></a> — dwa dopasowane, praktyczne dni szkoleniowe; od 6000 PLN + VAT.</li>
        <li><a href="/projekty-ai/"><strong>Projekty i wdrożenia AI</strong></a> — dłuższa współpraca od wyboru zastosowań i pilotażu po wsparcie wdrożenia; cena ustalana indywidualnie.</li>
        <li><strong>Prelekcje i wystąpienia o AI</strong> — konferencje, wydarzenia firmowe i spotkania dla kadry zarządzającej; zakres i cena ustalane indywidualnie.</li>
      </ul>

      <h2>Dla kogo i gdzie pracujemy</h2>
      <p>
        Główną grupą klientów są małe i średnie firmy, właściciele, managerowie oraz zespoły, które chcą
        zastosować AI w konkretnych procesach. Pracujemy stacjonarnie i online w całej Polsce, ze szczególnym
        uwzględnieniem <a href="/szkolenia-ai-poznan/">Wielkopolski</a>, Poznania, Inowrocławia i pobliskich miast.
        Projekty europejskie mogą być prowadzone po polsku lub po angielsku.
      </p>

      <h2>Doświadczenie i sposób pracy</h2>
      <p>
        Założycielem firmy jest <strong>Błażej Kunke</strong>, trener i konsultant AI. Praca z klientem zaczyna się
        od problemu biznesowego, danych i ryzyk, a nie od wyboru modnego narzędzia. Przykładem dłuższego projektu
        jest około sześciomiesięczna współpraca z kancelarią PragmatIQ, opisana na stronie
        <a href="/projekty-ai/">projektów AI</a> i w publicznym raporcie klienta.
      </p>

      <h2>Kontakt</h2>
      <ul>
        <li>E-mail: <a href="mailto:info@kunkeconsulting.pl">info@kunkeconsulting.pl</a></li>
        <li>Telefon: <a href="tel:+48722156925">+48 722 156 925</a></li>
        <li>LinkedIn: <a href="https://www.linkedin.com/in/blazejkunke/" rel="me">Błażej Kunke</a></li>
      </ul>

      <p class="updated">Informacje sprawdzone i zaktualizowane: <time datetime="2026-07-09">9 lipca 2026</time>.</p>
    </main>
  </body>
</html>
