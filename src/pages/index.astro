---
import BaseLayout from '../components/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import AiPackages from '../components/AiPackages.astro';
import Testimonials from '../components/testimonials.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import WorkshopSection from '../components/WorkshopSection.astro';
import OMnie from '../components/OMnie.astro';
import StudentReport from '../components/StudentReport.astro';
import SiteFooter from '../components/SiteFooter.astro';

---

<BaseLayout
  title="Szkolenia AI dla firm | ^Kunke Consulting | Warsztaty i wdrożenia AI w Polsce i Europie"
  description="Warsztaty i szkolenia AI dla średnich przedsiębiorstw w Polsce i Europie. Praktyczne wdrożenia ChatGPT, automatyzacja procesów, doradztwo AI. Dla zespołów 20-500 osób. Średnia ocena 98%. Transformacja cyfrowa z gwarancją rezultatów."
  ogImage="/images/Workshop2025.JPG"
>

<style>
  .team-center {
    text-align: center;
  }
  .contact-text {
    text-align: center;
    margin-bottom: 10px;
  }
  .contact-center {
    text-align: center;
    margin-bottom: 15px;
  }
  .contact-email {
    color: #2c3e50;
    text-decoration: none;
  }
  .hero-cta-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .hero-secondary-link {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }
  .hero-secondary-link:hover {
    text-decoration: underline;
  }
</style>

<section id="hero">
  <h1><span class="text-gradient">^Kunke Consulting</span></h1>
  <p>Praktyczne szkolenia i doradztwo AI dla biznesu.</p>
  <div class="hero-cta-group">
    <a href="/kalkulator-roi-ai/" class="cta-btn">Sprawdź, ile AI może zaoszczędzić firmie</a>
    <a href="#ai-packages" class="hero-secondary-link">Zobacz ofertę AI dla firm</a>
  </div>
</section>

<!-- Experience Section -->
<section id="experience">
  <ExperienceSection />
</section>

<!-- Workshop Section -->
<section id="workshops">
  <WorkshopSection />
</section>

<!-- Student Report Section -->
<section id="student-report">
  <StudentReport />
</section>

<!-- AI Packages Section -->
<section id="ai-packages">
  <AiPackages />
</section>


<!-- Testimonials Section -->
<section id="testimonials">
  <Testimonials />
</section>

<!-- About Me Section -->
<section id="about-me">
  <OMnie />
</section>

<!-- FAQ Section -->
<section id="faq" style="padding: 60px 20px; background: #f8f8fa;">
  <h2 style="text-align: center; margin-bottom: 50px;">Często zadawane pytania o szkolenia AI</h2>
  <div style="max-width: 800px; margin: 0 auto;">
    <div class="faq-accordion">
      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <h3>Czy szkolenia AI są odpowiednie dla początkujących?</h3>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <p>Tak! Nasze szkolenia AI dla firm są dostosowane do różnych poziomów zaawansowania. Zaczynamy od podstaw i stopniowo przechodzimy do bardziej zaawansowanych zastosowań AI w biznesie.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <h3>Gdzie odbywają się szkolenia AI?</h3>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <p>Oferujemy szkolenia AI w całej Polsce, w tym szkolenia AI Poznań, szkolenia AI Warszawa, szkolenia AI Łódź, oraz kursy AI online dla maksymalnej wygody uczestników.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <h3>Jak długo trwa szkolenie ChatGPT?</h3>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <p>Podstawowe szkolenie ChatGPT trwa 1 dzień, podczas gdy kompleksowe warsztaty AI dla firm mogą trwać kilka dni, w zależności od potrzeb organizacji.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <h3>Czy otrzymam certyfikat po szkoleniu AI?</h3>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <p>Tak, wszyscy uczestnicy otrzymują certyfikat ukończenia szkolenia AI oraz dostęp do materiałów szkoleniowych.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <h3>Jak AI może pomóc mojej firmie?</h3>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <p>AI pomaga usprawniać raportowanie, tworzyć trafniejsze analizy, oszczędzać czas na powtarzalnych zadaniach i podejmować lepsze decyzje biznesowe oparte na danych.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <h3>Co obejmuje konsulting AI dla firm?</h3>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <p>Nasz konsulting AI obejmuje audyt procesów, strategię implementacji AI, wybór odpowiednich narzędzi, szkolenia zespołu i wsparcie przy wdrażaniu rozwiązań AI w firmie.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" aria-expanded="false">
          <h3>Czy mogę zamówić szkolenia AI dla managerów?</h3>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-answer">
          <p>Oczywiście! Oferujemy specjalistyczne szkolenia AI dla managerów, które skupiają się na strategicznym wykorzystaniu AI, zarządzaniu zespołami w erze AI i podejmowaniu decyzji wspartych sztuczną inteligencją.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="ai-info" style="padding: 30px 20px; text-align: center;">
  <h2>AI and bot information access</h2>
  <p>Are you an AI, bot, or automated LLM looking for information about this company? Use our text-only, AI-friendly page with verified details about ^Kunke Consulting and founder Mr. Blazej Kunke.</p>
  <a href="/ai-info">FOR ROBOTS ONLY</a>
</section>

<style>
  .faq-accordion {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq-item {
    background: white;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,.05);
    border-left: 4px solid var(--color-primary);
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }
  .faq-item:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,.1);
  }
  .faq-question {
    width: 100%;
    background: none;
    border: none;
    padding: 25px;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background-color 0.2s ease;
  }
  .faq-question:hover {
    background-color: #f8f9fa;
  }
  .faq-question:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: -2px;
  }
  .faq-question h3 {
    color: var(--color-primary);
    margin: 0;
    font-size: 1.2rem;
    flex-grow: 1;
  }
  .faq-icon {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--color-primary);
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 20px;
  }
  .faq-item[data-expanded="true"] .faq-icon {
    transform: rotate(45deg);
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out, padding 0.3s ease-out;
    padding: 0 25px;
  }
  .faq-item[data-expanded="true"] .faq-answer {
    max-height: 200px;
    padding: 15px 25px 25px 25px;
  }
  .faq-answer p {
    margin: 0;
    line-height: 1.6;
    color: #555;
  }
  @media (max-width: 600px) {
    .faq-question {
      padding: 20px;
    }
    .faq-question h3 {
      font-size: 1.1rem;
    }
    .faq-icon {
      margin-left: 15px;
    }
    .faq-item[data-expanded="true"] .faq-answer {
      padding: 15px 20px 20px 20px;
    }
  }
</style>

<section id="contact">
  <h2>Kontakt</h2>
  <p class="contact-text">Napisz mi email lub skorzystaj z formularza poniżej.</p>
  <div class="contact-info contact-center">
    <p><strong>Email:</strong> <a href="mailto:info@kunkeconsulting.pl" class="contact-email">info@kunkeconsulting.pl</a></p>
  </div>
  <!-- New Contact Form -->
  <ContactForm />
</section>

<SiteFooter />

<script>
// @ts-nocheck
  document.addEventListener('DOMContentLoaded', function() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question');
      const answer = item.querySelector('.faq-answer');
      
      question.addEventListener('click', function() {
        const isExpanded = item.getAttribute('data-expanded') === 'true';
        
        // Close all other items
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.setAttribute('data-expanded', 'false');
            otherItem.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
          }
        });
        
        // Toggle current item
        const newExpandedState = !isExpanded;
        item.setAttribute('data-expanded', newExpandedState.toString());
        question.setAttribute('aria-expanded', newExpandedState.toString());
        
        // Adjust max-height for smooth animation
        if (newExpandedState) {
          answer.style.maxHeight = answer.scrollHeight + 'px';
        } else {
          answer.style.maxHeight = '0px';
        }
      });
      
      // Keyboard navigation
      question.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          question.click();
        }
      });
    });
  });
</script>

</BaseLayout>
