---
import BaseLayout from '../../components/BaseLayoutUk.astro';
import ContactForm from '../../components/ContactFormEn.astro';
import AiPackages from '../../components/AiPackagesEn.astro';
import Testimonials from '../../components/testimonialsEn.astro';
import ExperienceSection from '../../components/ExperienceSectionEn.astro';
import WorkshopSection from '../../components/WorkshopSectionEn.astro';
import AboutMe from '../../components/AboutMeEn.astro';
import StudentReport from '../../components/StudentReportEn.astro';
---

<BaseLayout
  title="AI Training and Consulting for UK Teams | ^Kunke Consulting"
  description="Practical AI consultation, team training, and implementation support for UK organisations. AI consultations from £280 + VAT and team training from £1,200 + VAT."
  ogImage="/images/Workshop2025.JPG"
>
  <style>
    #hero {
      text-align: center;
      padding: 72px 20px 56px;
      background: linear-gradient(180deg, #f6fbff 0%, #ffffff 100%);
    }

    #hero .brand {
      color: var(--color-primary);
      font-weight: 700;
      margin-bottom: 12px;
    }

    #hero h1 {
      max-width: 960px;
      margin: 0 auto 18px;
      color: var(--color-primary);
      font-size: clamp(2.2rem, 4.6vw, 3.7rem);
      line-height: 1.08;
    }

    #hero .lead {
      max-width: 820px;
      margin: 0 auto 18px;
      color: #2c3e50;
      font-size: 1.16rem;
      line-height: 1.65;
    }

    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      margin: 22px auto 24px;
    }

    .hero-meta span {
      border: 1px solid #d8e5ef;
      border-radius: 999px;
      padding: 8px 14px;
      background: #fff;
      color: #24384d;
      font-weight: 600;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 20px;
      border-radius: 8px;
      background: var(--color-primary);
      color: #fff;
      font-weight: 700;
      text-decoration: none;
      box-shadow: 0 10px 24px rgba(10, 71, 49, 0.18);
    }

    .cta-btn.secondary {
      background: #ffffff;
      color: var(--color-primary);
      border: 1px solid #bfd2c9;
      box-shadow: none;
    }

    .uk-summary {
      padding: 54px 20px;
      background: #f8f8fa;
    }

    .summary-grid {
      max-width: 1080px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 18px;
    }

    .summary-card {
      background: #fff;
      border: 1px solid #dfe7ef;
      border-radius: 8px;
      padding: 22px;
    }

    .summary-card h2 {
      margin: 0 0 10px;
      color: var(--color-primary);
      font-size: 1.24rem;
    }

    .summary-card p {
      margin: 0;
      color: #465464;
      line-height: 1.55;
    }

    #contact {
      padding: 64px 20px;
      background: #f8f8fa;
    }

    footer {
      background: #f8f8fa;
      padding: 40px 20px 24px;
      text-align: center;
      color: #555;
    }

    footer a {
      color: var(--color-primary);
    }
  </style>

  <section id="hero">
    <p class="brand">^Kunke Consulting</p>
    <h1>Practical AI training and implementation support for UK teams</h1>
    <p class="lead">
      I help British organisations move from AI curiosity to concrete use cases, team playbooks, and responsible pilots
      that fit real business processes.
    </p>
    <div class="hero-meta" aria-label="UK AI offer highlights">
      <span>Consultation from £280 + VAT</span>
      <span>Team training from £1,200 + VAT</span>
      <span>Online or on-site where applicable</span>
    </div>
    <div class="hero-actions">
      <a href="#ai-packages" class="cta-btn">Compare AI options</a>
      <a href="#contact" class="cta-btn secondary">Discuss a UK project</a>
    </div>
  </section>

  <section class="uk-summary" aria-label="UK AI services summary">
    <div class="summary-grid">
      <article class="summary-card">
        <h2>Fast diagnosis</h2>
        <p>A 90-minute consultation to identify realistic AI quick wins, tool choices, risks, and next steps.</p>
      </article>
      <article class="summary-card">
        <h2>Team capability</h2>
        <p>Hands-on AI training for teams that need practical skills, shared standards, and useful internal playbooks.</p>
      </article>
      <article class="summary-card">
        <h2>Implementation support</h2>
        <p>Ongoing help with pilots, adoption, governance, and measurable process improvements.</p>
      </article>
    </div>
  </section>

  <section id="experience">
    <ExperienceSection />
  </section>

  <section id="workshops">
    <WorkshopSection />
  </section>

  <section id="student-report">
    <StudentReport />
  </section>

  <section id="ai-packages">
    <AiPackages />
  </section>

  <section id="testimonials">
    <Testimonials />
  </section>

  <section id="about-me">
    <AboutMe />
  </section>

  <section id="contact">
    <ContactForm />
  </section>

  <footer>
    <p>© 2026 ^Kunke Consulting. AI consulting and training for teams in Poland, the UK, and across Europe.</p>
    <p><a href="mailto:info@kunkeconsulting.pl">info@kunkeconsulting.pl</a></p>
  </footer>
</BaseLayout>
