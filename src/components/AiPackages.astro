---
// props could be used later for localisation; hard-coded for now
const packages = [
  {
    id: 'plant',
    title: 'Szkolenie AI dla firm',
    tagline: 'Wprowadź AI, zyskaj przewagę',
    price: 'Od 6000 zł + VAT',
    badge: null,
    bullets: [
      'Dwa szkolenia stacjonarne',
      'Praktyczne narzędzia AI',
      'Inżynieria promptu',
      'AI video, AI obrazy, AI dźwięk',
      'Etyka, środowisko, prawo AI',
      'Prezentacja PDF, certyfikat',
      'Naturalny pierwszy krok z AI'
    ],
    calendly: 'https://calendly.com/kunkeconsulting-info/30min',
    href: '/ai-workshop/',
    cta: 'Zacznij od szkolenia'
  },
  {
    id: 'grow',
    title: 'Wdrożenie AI',
    tagline: 'Program szyty na miarę Twojej firmy',
    price: 'Cena ustalana indywidualnie',
    bullets: [
      'Badanie potrzeb zespołu',
      'Ustalenie strategii AI',
      'Warsztat możliwości i inspiracji',
      'Mapowanie konkretnych zastosowań',
      'Pierwsi asystenci AI',
      'Konsultacja z prawnikiem AI (RODO, AI Act)',
      'Pilotaż rozwiązań AI'
    ],
    note: 'Ograniczona liczba równoległych wdrożeń',
    badge: 'AI dla firm',
    calendly: 'https://calendly.com/kunkeconsulting-info/30min',
    href: '/ai-dla-firm/',
    cta: 'Dowiedz się więcej'
  },
  {
    id: 'flourish',
    title: 'Projekty AI',
    tagline: 'Stała współpraca',
    price: 'Cena ustalana indywidualnie',
    badge: null,
    bullets: [
      'Stała współpraca w obszarze AI',
      'Działania długofalowe',
      'Najbardziej ambitne projekty',
      'Asystenci AI dla zespołów',
      'Szkolenia zespołów',
      'Wsparcie IT',
      'Wsparcie prawne AI',
      'Konsulting AI'
    ],
    calendly: 'https://calendly.com/kunkeconsulting-info/30min',
    href: '/projekty-ai/',
    cta: 'Porozmawiajmy'
  }
];
---
<section id="ai-packages">
  <h2>Szkolenia i doradztwo AI</h2>

  <div class="package-grid">
    {packages.map(pkg => (
      <article class="card {pkg.id}">
        {pkg.badge && <span class="badge">{pkg.badge}</span>}

        <h3>{pkg.title}</h3>
        <p class="tagline">{pkg.tagline}</p>

        <div class="content">
          <ul>
            {pkg.bullets.map(b => <li>{b}</li>)}
          </ul>
          {pkg.note && <p class="package-note">{pkg.note}</p>}

          <div class="spacer" />
          <p class="price" set:html={pkg.price} />

          {pkg.calendly
            ? <a href={pkg.href} class="cta">{pkg.cta}</a>
            : <a href="#contact" class="cta secondary">Skontaktuj się</a>}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  /* ----- layout ----- */
  #ai-packages { padding: 60px 20px; background:#fff; text-align:center; }
  .package-grid {
    display:flex; gap:24px; flex-wrap:wrap; justify-content:center;
  }
  .card {
    flex:1 1 280px; max-width:320px;
    background:#f8f8fa; border-radius:12px; padding:32px 24px;
    position:relative; box-shadow:0 4px 12px rgba(0,0,0,.06);
    display:flex; flex-direction:column; align-items:center;
  }
  h3 { margin:8px 0 4px; }
  .tagline { font-size:.95rem; color:#555; margin-bottom:16px; }
  ul { text-align:left; padding-left:18px; margin:0 0 24px; }
  li { margin-bottom:6px; }
  .package-note { text-align:left; margin:-8px 0 24px; color:#333; }
  .price { font-weight:700; margin-bottom:24px; }
  .price .old-price { text-decoration:line-through; color:#888; font-weight:400; }
  .cta {
    background:var(--color-primary); color:#fff; padding:12px 24px;
    border-radius:6px; text-decoration:none; font-weight:600;
    transition:background .3s ease;
  }
  .cta:hover { background:var(--color-secondary); }
  .cta.secondary { background:#ccc; }
  .badge {
    position:absolute; top:12px; right:12px;
    background:var(--color-accent-blue); color:#fff; font-size:.75rem;
    padding:4px 8px; border-radius:4px;
  }
  /* mobile stack */
  @media(max-width:700px){ .package-grid{flex-direction:column;} }
</style>
